#!/usr/bin/env bash
# Codex SessionStart hook for cybersec plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_cybersec_content=$(cat "${PLUGIN_ROOT}/skills/using-cybersec/SKILL.md" 2>&1 || echo "Error reading using-cybersec skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_cybersec_escaped=$(escape_for_json "$using_cybersec_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have CYBERSEC SUPERPOWERS.\n\n**IMPORTANT: The using-cybersec skill content is included below. It is ALREADY LOADED - you are currently following it.**\n\n${using_cybersec_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context" | cat

exit 0